# ---- Database (local Postgres via Homebrew) ----
# postgresql://<user>:<password>@<host>:<port>/<db>?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hotel_platform?schema=public"

# ---- Auth.js (NextAuth v5) ----
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-random-32-byte-base64-string"
# Base URL of the app (used by Auth.js and Xendit redirects)
NEXTAUTH_URL="http://localhost:3000"

# ---- Xendit (test mode) ----
# Secret API key from the Xendit dashboard (test mode)
XENDIT_SECRET_KEY="xnd_development_replace_me"
# Callback verification token configured for the webhook endpoint
XENDIT_WEBHOOK_TOKEN="replace-me-with-your-xendit-callback-token"

# ---- App ----
# Public base URL used to build invoice success/failure redirect URLs
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
