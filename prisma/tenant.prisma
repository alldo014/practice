// Per-tenant operational schema. These models are NOT migrated into `public`.
// Instead, an identical set of tables is created inside each `tenant_<...>`
// schema from the generated DDL template (prisma/tenant-template.sql), and
// getTenantDb(schemaName) points a client at the right schema at runtime.
//
// Keep this file as the single source of truth: after editing it, regenerate
// the DDL template with `npm run prisma:tenant:ddl`.
generator tenantClient {
  provider = "prisma-client-js"
  output   = "../src/generated/tenant"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hotel {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  city        String
  country     String
  description String
  starRating  Int      @map("star_rating")
  address     String?
  coverImage  String   @map("cover_image")
  amenities   String[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  rooms       Room[]

  @@map("hotels")
}

model Room {
  id          String    @id @default(cuid())
  hotelId     String    @map("hotel_id")
  hotel       Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  type        String
  description String?
  capacity    Int
  beds        Int       @default(1)
  basePrice   Decimal   @map("base_price") @db.Decimal(12, 2)
  currency    String    @default("IDR")
  photos      String[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  bookings    Booking[]

  @@map("rooms")
}

model Booking {
  id            String   @id @default(cuid())
  roomId        String   @map("room_id")
  room          Room     @relation(fields: [roomId], references: [id], onDelete: Restrict)
  guestId       String   @map("guest_id") // references public.users.id (no cross-schema FK)
  guestEmail    String   @map("guest_email")
  checkIn       DateTime @map("check_in") @db.Date
  checkOut      DateTime @map("check_out") @db.Date
  guests        Int      @default(1)
  totalAmount   Decimal  @map("total_amount") @db.Decimal(12, 2)
  currency      String   @default("IDR")
  status        String   @default("pending") // pending | confirmed | cancelled
  paymentStatus String   @default("unpaid") @map("payment_status") // unpaid | paid | failed
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  payment       Payment?

  @@index([roomId, checkIn, checkOut])
  @@map("bookings")
}

model Payment {
  id              String   @id @default(cuid())
  bookingId       String   @unique @map("booking_id")
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  xenditInvoiceId String?  @map("xendit_invoice_id")
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("IDR")
  status          String   @default("pending") // pending | paid | failed | expired
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("payments")
}
